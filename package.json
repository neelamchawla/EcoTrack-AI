{
  "name": "ecotrack-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "emulators": "firebase emulators:start --only auth,firestore",
    "rules:validate": "firebase deploy --only firestore:rules --dry-run"
  },
  "dependencies": {
    "firebase": "^11.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "firebase-tools": "^15.22.0",
    "jsdom": "^22.1.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^4.5.2",
    "vitest": "^0.34.6"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "vitest": {
      "vite": "$vite"
    }
  }
}
