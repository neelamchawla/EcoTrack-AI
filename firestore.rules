rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches Firebase Auth UID)
    // Fields:
    //   - displayName: string (required, 1-50 chars) - public display name
    //   - weeklyGoalKg: number (required, 0-1000) - weekly CO2 reduction goal
    //   - createdAt: timestamp (required, immutable) - account creation time
    //   - updatedAt: timestamp (required) - last profile update
    //
    // Collection: activities
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, immutable) - owner UID
    //   - category: string (required) - transport | food | energy | shopping | other
    //   - description: string (required, 1-200 chars) - short activity label
    //   - co2Kg: number (required, 0-10000) - estimated CO2 in kilograms
    //   - recordedAt: timestamp (required) - when the activity occurred
    //   - createdAt: timestamp (required, immutable) - when the entry was logged
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function isRecent(time) {
      return time is timestamp &&
        time > request.time - duration.value(5, 'm') &&
        time <= request.time;
    }

    function isValidCategory(category) {
      return category in ['transport', 'food', 'energy', 'shopping', 'other'];
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['displayName', 'weeklyGoalKg', 'createdAt', 'updatedAt']) &&
        data.displayName is string &&
        data.displayName.size() >= 1 &&
        data.displayName.size() <= 50 &&
        data.weeklyGoalKg is number &&
        data.weeklyGoalKg >= 0 &&
        data.weeklyGoalKg <= 1000 &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp;
    }

    function isValidUserCreate(data) {
      return isValidUser(data) &&
        data.createdAt == request.time &&
        data.updatedAt == request.time;
    }

    function isValidUserUpdate(data) {
      return isValidUser(data) &&
        data.createdAt == resource.data.createdAt &&
        data.updatedAt == request.time;
    }

    function isValidActivity(data) {
      return hasOnlyAllowedFields(['uid', 'category', 'description', 'co2Kg', 'recordedAt', 'createdAt']) &&
        data.uid is string &&
        data.uid.size() >= 1 &&
        data.uid.size() <= 128 &&
        isValidCategory(data.category) &&
        data.description is string &&
        data.description.size() >= 1 &&
        data.description.size() <= 200 &&
        data.co2Kg is number &&
        data.co2Kg >= 0 &&
        data.co2Kg <= 10000 &&
        data.recordedAt is timestamp &&
        data.createdAt is timestamp;
    }

    function isValidActivityCreate(data) {
      return isValidActivity(data) &&
        data.uid == request.auth.uid &&
        data.createdAt == request.time &&
        data.recordedAt <= request.time;
    }

    function isValidActivityUpdate(data) {
      return isValidActivity(data) &&
        data.uid == resource.data.uid &&
        data.createdAt == resource.data.createdAt;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserCreate(request.resource.data);
      allow update: if isOwner(userId) && isValidUserUpdate(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /activities/{activityId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() &&
        uidUnchanged() &&
        isValidActivityCreate(request.resource.data);
      allow update: if isDocOwner() &&
        uidNotModified() &&
        isValidActivityUpdate(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
